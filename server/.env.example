# Server Configuration
PORT=3000

# CDP (Coinbase Developer Platform) Credentials
# Get from: https://portal.cdp.coinbase.com/projects
CDP_API_KEY_ID=your-cdp-api-key-id
CDP_API_KEY_SECRET=your-cdp-api-key-secret
BASE_RPC_URL=https://your-base-rpc-url
PLATFORM_API_BASE_URL=https://your-platform-api-base-url

# Auth verification
PRIVY_APP_ID=your-privy-app-id
PRIVY_VERIFICATION_KEY=your-privy-verification-key

# Coinbase custom sign-in tokens
REGENTS_CDP_JWT_ISSUER=https://your-backend-domain
REGENTS_CDP_JWT_AUDIENCE=coinbase-cloud
REGENTS_CDP_JWT_KID=regents-mobile
REGENTS_CDP_JWT_ALG=ES256
REGENTS_CDP_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"

# Note: Phone and Email verification can now be handled by CDP Embedded Wallets
# Users can sign in with either email or phone, and link additional methods.

# Webhook Security
# Get this from Coinbase Developer Portal when creating webhook
# The signing secret is provided in the webhook creation response
WEBHOOK_SECRET=your-webhook-signing-secret

# CORS Allowed sites (if backend required for other websites, not required for mobile)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: APNs Configuration (for production iOS push notifications)
# Get from: https://developer.apple.com/account/resources/authkeys/list
# Leave empty to use Expo Push Service in development
APNS_KEY_ID=
APNS_TEAM_ID=
# Paste your .p8 file content as a single line (replace newlines with \n)
APNS_KEY=

# Optional: Redis URL for production push-token storage
# Leave empty to use in-memory storage in development
REDIS_URL=

# Optional: backend-owned state directory for mobile wallet intent records
REGENTS_MOBILE_STATE_DIR=
